generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  name         String
  role         String   @default("USER") // USER, ORGANIZER
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  quizzes      Quiz[]
  participants Participant[]
  // Убираем answers отсюда, так как Answer связан через Participant
}

model Quiz {
  id          String   @id @default(cuid())
  title       String
  description String?
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  questions   Question[]
  sessions    GameSession[]
}

model Question {
  id             String   @id @default(cuid())
  quizId         String
  quiz           Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  type           String   @default("TEXT") // TEXT, IMAGE
  selectionType  String   @default("SINGLE") // SINGLE, MULTIPLE
  text           String
  imageUrl       String?
  options        String   // JSON string
  correctAnswer  String   // JSON string
  timeLimit      Int      @default(30)
  points         Int      @default(10)
  order          Int      @default(0)
  
  answers        Answer[]
}

model GameSession {
  id                  String      @id @default(cuid())
  quizId              String
  quiz                Quiz        @relation(fields: [quizId], references: [id], onDelete: Cascade)
  code                String      @unique
  status              String      @default("WAITING") // WAITING, ACTIVE, FINISHED
  currentQuestionIndex Int       @default(0)
  startedAt           DateTime?
  finishedAt          DateTime?
  createdAt           DateTime    @default(now())
  
  participants        Participant[]
}

model Participant {
  id          String   @id @default(cuid())
  sessionId   String
  session     GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestName   String?
  score       Int      @default(0)
  joinedAt    DateTime @default(now())
  
  answers     Answer[]
}

model Answer {
  id              String   @id @default(cuid())
  participantId   String
  participant     Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  questionId      String
  question        Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOptions String   // JSON string
  isCorrect       Boolean
  pointsEarned    Int      @default(0)
  timeMs          Int      @default(0)
  createdAt       DateTime @default(now())
}